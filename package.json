{
	"name": "metadata-labels",
	"version": "0.1.0",
	"description": "Visual labels from frontmatter metadata for Obsidian notes, folders, and properties.",
	"homepage": "https://github.com/anthony/obsidian-metadata-labels#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/anthony/obsidian-metadata-labels.git"
	},
	"bugs": {
		"url": "https://github.com/anthony/obsidian-metadata-labels/issues"
	},
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin",
		"metadata",
		"frontmatter",
		"labels"
	],
	"author": "Anthony Fitzpatrick",
	"license": "0BSD",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.4.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1"
	}
}
